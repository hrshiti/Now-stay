# Copy to .env and fill values. Do not commit .env or service account JSON.

MONGODB_URL=
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:1573
JWT_SECRET=
JWT_EXPIRES_IN=7d

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

GOOGLE_MAP_API_KEY=

SMSINDIAHUB_API_KEY=
SMSINDIAHUB_SENDER_ID=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_ACCOUNT_NUMBER=

# Firebase Admin (push notifications). Path to service account JSON file.
# Development: ./serviceAccountKey.json (file in backend folder; add to .gitignore)
# Production: use absolute path, e.g. /var/run/secrets/firebase/serviceAccountKey.json (mount secret at deploy)
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
